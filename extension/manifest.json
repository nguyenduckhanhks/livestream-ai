{
  "manifest_version": 3,
  "name": "AI Bridge Extension",
  "version": "1.0",
  "description": "Bridges local API requests to ChatGPT and DeepSeek",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://chatgpt.com/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
